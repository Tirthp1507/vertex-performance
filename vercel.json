{
  "version": 2,
  "buildCommand": "pnpm install && pnpm run build",
  "outputDirectory": "dist",
  "env": {
    "NODE_ENV": "production"
  },
  "routes": [
    {
      "src": "^/index.js$",
      "dest": "/index.js"
    },
    {
      "src": "^/(?!index\\.js|.*\\.[^/]+$).*$",
      "dest": "/index.html"
    },
    {
      "src": "^/(.*\\.[^/]+)$",
      "dest": "/$1"
    }
  ]
}
